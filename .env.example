# OpenSearch
OPENSEARCH_URL=http://opensearch:9200
STATE_INDEX=tfm-triaje-state
HISTORY_INDEX=tfm-triaje-history

# Modelo ML L1
T_ALLOW=0.92
T_BLOCK=0.20

# TTLs
PROVISIONAL_ALLOW_TTL_MINUTES=15
PROVISIONAL_BLOCK_TTL_HOURS=24
TTL_CLEAN_DAYS=60
TTL_MALICIOUS_DAYS=7

# Scope de ingesta
ALLOWED_CATEGORIES=0,90,91
ALLOWED_SERVICE=HTTPS
BLOCK_NONSTANDARD_HTTPS_PORTS=0

# Worker / LLM
OLLAMA_URL=http://host.docker.internal:11434/api/generate
OLLAMA_MODEL=qwen3.5:35b-a3b-q8_0
OLLAMA_NUM_CTX=4096
OLLAMA_TEMPERATURE=0.0
WORKER_POLL_SECONDS=5

# Claves API OSINT
VT_API_KEY=
OTX_API_KEY=
URLSCAN_API_KEY=
GSB_API_KEY=
ABUSECH_API_KEY=

